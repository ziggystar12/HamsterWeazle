<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HamsterWeazle.App"
             Name="HamsterWeazle"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />
    <!-- HamsterWeazle theme (Dark or Amiga) is loaded dynamically at startup -->
    <!-- via App.SwitchTheme() in OnFrameworkInitializationCompleted           -->
  </Application.Styles>
</Application>
