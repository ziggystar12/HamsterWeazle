<Window x:Class="HamsterWeazle.SetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HamsterWeazle Setup"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="False"
        Width="480" Height="330"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Win.Panel}">

  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="32" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="0"/>
  </WindowChrome.WindowChrome>

  <Border BorderBrush="{DynamicResource Win.Separator}" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="32"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Grid Grid.Row="0" Background="{DynamicResource Win.TitleBar.BG}"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <TextBlock Text="GreaseWeazle Setup"
                   Foreground="{DynamicResource Win.TitleBar.FG}"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="13" FontWeight="SemiBold"
                   VerticalAlignment="Center" Margin="12,0"/>
      </Grid>

      <!-- Content -->
      <StackPanel Grid.Row="1" Margin="24,20,24,20">

        <TextBlock Text="GreaseWeazle Host Tools Not Found"
                   Foreground="{DynamicResource Win.Text}"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="15" FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <TextBlock Text="To read and write floppy disks you need the GreaseWeazle host tools (gw.exe). You can download them automatically or point to an existing installation."
                   Foreground="{DynamicResource Win.SubText}"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="{DynamicResource Win.FontSize}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,20"/>

        <!-- Download button -->
        <Button x:Name="BtnDownload"
                Style="{DynamicResource PrimaryBtn}"
                Content="Checking for latest version..."
                HorizontalAlignment="Stretch" Height="38"
                IsEnabled="False"
                Click="BtnDownload_Click"
                Margin="0,0,0,8"/>

        <!-- Progress bar -->
        <ProgressBar x:Name="ProgressBar"
                     Height="6" Margin="0,0,0,4"
                     Visibility="Collapsed"
                     Foreground="{DynamicResource Win.Accent}"
                     Background="{DynamicResource Win.Input.BG}"
                     BorderBrush="{DynamicResource Win.Separator}"/>

        <!-- Status text -->
        <TextBlock x:Name="TxtStatus"
                   Foreground="{DynamicResource Win.SubText}"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="{DynamicResource Win.FontSize}"
                   Visibility="Collapsed"
                   Margin="0,0,0,12"/>

        <!-- Browse existing -->
        <Button x:Name="BtnBrowse"
                Style="{DynamicResource GhostBtn}"
                Content="Browse to Existing Installation..."
                HorizontalAlignment="Stretch" Height="34"
                Click="BtnBrowse_Click"
                Margin="0,0,0,8"/>

        <!-- Skip -->
        <Button x:Name="BtnSkip"
                Style="{DynamicResource GhostBtn}"
                Content="Skip for now"
                HorizontalAlignment="Right" Height="28"
                Click="BtnSkip_Click"/>

      </StackPanel>
    </Grid>
  </Border>
</Window>
