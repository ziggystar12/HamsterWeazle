<Window x:Class="HamsterWeazle.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="False" Width="680" Height="660"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Win.Panel}">
  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="32" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="0"/>
  </WindowChrome.WindowChrome>
  <Border BorderBrush="{DynamicResource Win.Separator}" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="32"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Grid Grid.Row="0" Background="{DynamicResource Win.TitleBar.BG}"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Settings"
                   Foreground="{DynamicResource Win.TitleBar.FG}"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="13" FontWeight="SemiBold"
                   VerticalAlignment="Center" Margin="12,0"/>
        <Button Grid.Column="1" Style="{DynamicResource GhostBtn}"
                Foreground="{DynamicResource Win.TitleBar.FG}"
                Content="X" Width="46" Height="32" Click="BtnClose_Click"
                WindowChrome.IsHitTestVisibleInChrome="True"/>
      </Grid>
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,20">
          <TextBlock Text="ABOUT" Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="24"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="HamsterWeazle" Foreground="{DynamicResource Win.Text}"
                         FontFamily="{DynamicResource Win.FontMain}"
                         FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
              <TextBlock x:Name="TxtVersion" Foreground="{DynamicResource Win.SubText}"
                         FontFamily="{DynamicResource Win.FontMain}"
                         FontSize="{DynamicResource Win.FontSize}" Margin="0,0,0,4"/>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="John Swiderski  &#183;  "
                           Foreground="{DynamicResource Win.SubText}"
                           FontFamily="{DynamicResource Win.FontMain}"
                           FontSize="{DynamicResource Win.FontSize}" VerticalAlignment="Center"/>
                <Button x:Name="BtnMeanHamster" Style="{DynamicResource GhostBtn}"
                        Content="Mean Hamster Software" Foreground="{DynamicResource Win.Accent}"
                        Padding="0" Height="22" Click="BtnMeanHamster_Click"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Product page: " Foreground="{DynamicResource Win.SubText}"
                           FontFamily="{DynamicResource Win.FontMain}"
                           FontSize="{DynamicResource Win.FontSize}" VerticalAlignment="Center"/>
                <Button x:Name="BtnGitHub" Style="{DynamicResource GhostBtn}"
                        Content="meanhamster.com/products/hamsterweazle" Foreground="{DynamicResource Win.Accent}"
                        Padding="0" Height="22" Click="BtnGitHub_Click"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="GreaseWeazle: " Foreground="{DynamicResource Win.SubText}"
                           FontFamily="{DynamicResource Win.FontMain}"
                           FontSize="{DynamicResource Win.FontSize}" VerticalAlignment="Center"/>
                <Button x:Name="BtnGwGitHub" Style="{DynamicResource GhostBtn}"
                        Content="github.com/keirf/greaseweazle" Foreground="{DynamicResource Win.Accent}"
                        Padding="0" Height="22" Click="BtnGwGitHub_Click"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="HxCFloppyEmulator: " Foreground="{DynamicResource Win.SubText}"
                           FontFamily="{DynamicResource Win.FontMain}"
                           FontSize="{DynamicResource Win.FontSize}" VerticalAlignment="Center"/>
                <Button x:Name="BtnHxcGitHub" Style="{DynamicResource GhostBtn}"
                        Content="github.com/jfdelnero/HxCFloppyEmulator" Foreground="{DynamicResource Win.Accent}"
                        Padding="0" Height="22" Click="BtnHxcGitHub_Click"/>
              </StackPanel>
            </StackPanel>
            <Image Grid.Column="2" Source="pack://application:,,,/Assets/logo.png"
                   Width="131" Height="120" Stretch="Uniform"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
          </Grid>
          <Rectangle Style="{DynamicResource HSep}" Margin="0,0,0,16"/>
          <TextBlock Text="SOFTWARE UPDATES" Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="150"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
              <TextBlock Text="HamsterWeazle" Foreground="{DynamicResource Win.Text}"
                         FontFamily="{DynamicResource Win.FontMain}" FontSize="{DynamicResource Win.FontSize}"/>
              <TextBlock x:Name="TxtHwInstalled" Foreground="{DynamicResource Win.SubText}"
                         FontFamily="{DynamicResource Win.FontMono}" FontSize="11"/>
            </StackPanel>
            <TextBlock x:Name="TxtHwUpdateStatus" Grid.Column="1"
                       Foreground="{DynamicResource Win.SubText}"
                       FontFamily="{DynamicResource Win.FontMain}" FontSize="{DynamicResource Win.FontSize}"
                       VerticalAlignment="Center" Margin="8,0"/>
            <Button x:Name="BtnUpdateHw" Grid.Column="2" Style="{DynamicResource PrimaryBtn}"
                    Content="Update Now" Height="30" Margin="0,0,6,0"
                    Visibility="Collapsed" Click="BtnUpdateHw_Click"/>
            <Button x:Name="BtnCheckHw" Grid.Column="3" Style="{DynamicResource PrimaryBtn}"
                    Content="Check" Height="30" Click="BtnCheckHw_Click"/>
          </Grid>
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="150"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
              <TextBlock Text="gw.exe" Foreground="{DynamicResource Win.Text}"
                         FontFamily="{DynamicResource Win.FontMain}" FontSize="{DynamicResource Win.FontSize}"/>
              <TextBlock x:Name="TxtGwInstalled" Foreground="{DynamicResource Win.SubText}"
                         FontFamily="{DynamicResource Win.FontMono}" FontSize="11"/>
            </StackPanel>
            <TextBlock x:Name="TxtGwUpdateStatus" Grid.Column="1"
                       Foreground="{DynamicResource Win.SubText}"
                       FontFamily="{DynamicResource Win.FontMain}" FontSize="{DynamicResource Win.FontSize}"
                       VerticalAlignment="Center" Margin="8,0"/>
            <Button x:Name="BtnUpdateGw" Grid.Column="2" Style="{DynamicResource PrimaryBtn}"
                    Content="Update Now" Height="30" Margin="0,0,6,0"
                    Visibility="Collapsed" Click="BtnUpdateGw_Click"/>
            <Button x:Name="BtnCheckGw" Grid.Column="3" Style="{DynamicResource PrimaryBtn}"
                    Content="Check" Height="30" Click="BtnCheckGw_Click"/>
          </Grid>
          <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="150"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
              <TextBlock Text="HxCFloppyEmulator" Foreground="{DynamicResource Win.Text}"
                         FontFamily="{DynamicResource Win.FontMain}" FontSize="{DynamicResource Win.FontSize}"/>
              <TextBlock x:Name="TxtHxcInstalled" Foreground="{DynamicResource Win.SubText}"
                         FontFamily="{DynamicResource Win.FontMono}" FontSize="11"/>
            </StackPanel>
            <TextBlock x:Name="TxtHxcUpdateStatus" Grid.Column="1"
                       Foreground="{DynamicResource Win.SubText}"
                       FontFamily="{DynamicResource Win.FontMain}" FontSize="{DynamicResource Win.FontSize}"
                       VerticalAlignment="Center" Margin="8,0"/>
            <Button x:Name="BtnUpdateHxc" Grid.Column="2" Style="{DynamicResource PrimaryBtn}"
                    Content="Update Now" Height="30" Margin="0,0,6,0"
                    Visibility="Collapsed" Click="BtnUpdateHxc_Click"/>
            <Button x:Name="BtnCheckHxc" Grid.Column="3" Style="{DynamicResource PrimaryBtn}"
                    Content="Check" Height="30" Click="BtnCheckHxc_Click"/>
          </Grid>
          <Rectangle Style="{DynamicResource HSep}" Margin="0,0,0,16"/>
          <TextBlock Text="THEME" Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <RadioButton x:Name="RbDark" Content="Dark" GroupName="Theme"
                         Foreground="{DynamicResource Win.Text}"
                         FontFamily="{DynamicResource Win.FontMain}" FontSize="{DynamicResource Win.FontSize}"
                         VerticalAlignment="Center" Margin="0,0,24,0" Checked="RbTheme_Checked"/>
            <RadioButton x:Name="RbAmiga" Content="Amiga Workbench" GroupName="Theme"
                         Foreground="{DynamicResource Win.Text}"
                         FontFamily="{DynamicResource Win.FontMain}" FontSize="{DynamicResource Win.FontSize}"
                         VerticalAlignment="Center" Checked="RbTheme_Checked"/>
          </StackPanel>
          <Rectangle Style="{DynamicResource HSep}" Margin="0,0,0,16"/>
          <TextBlock Text="INSTALLATION" Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="60"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="gw.exe"/>
            <TextBox x:Name="TxtGwPath" Grid.Column="1" IsReadOnly="True"/>
            <Button x:Name="BtnChangeGw" Grid.Column="2" Style="{DynamicResource GhostBtn}"
                    Content="Change..." Padding="8,0" Height="30" Click="BtnChangeGw_Click"/>
          </Grid>
          <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="60"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="HxC"/>
            <TextBox x:Name="TxtHxcPath" Grid.Column="1" IsReadOnly="True"/>
            <Button x:Name="BtnChangeHxc" Grid.Column="2" Style="{DynamicResource GhostBtn}"
                    Content="Change..." Padding="8,0" Height="30" Click="BtnChangeHxc_Click"/>
          </Grid>
          <Rectangle Style="{DynamicResource HSep}" Margin="0,0,0,16"/>
          <Border Background="{DynamicResource Win.Panel2}"
                  BorderBrush="{DynamicResource Win.Separator}"
                  BorderThickness="1" Padding="12,10" Margin="0,0,0,16"
                  CornerRadius="{DynamicResource Win.Corner}">
            <StackPanel>
              <TextBlock Text="LICENSE" Foreground="{DynamicResource Win.SubText}"
                         FontFamily="{DynamicResource Win.FontMain}"
                         FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
              <TextBlock TextWrapping="Wrap" LineHeight="20"
                         Foreground="{DynamicResource Win.Text}"
                         FontFamily="{DynamicResource Win.FontMain}"
                         FontSize="{DynamicResource Win.FontSize}">
                <Run FontWeight="SemiBold">Copyright &#169; 2026 Mean Hamster Software &#8212; John Swiderski.</Run>
                <Run> All rights reserved.</Run>
                <LineBreak/>
                <LineBreak/>
                <Run>Free to download and use for personal and non-commercial purposes.</Run>
                <LineBreak/>
                <Run>Modification and redistribution are not permitted without written permission.</Run>
                <LineBreak/>
                <LineBreak/>
                <Run Foreground="{DynamicResource Win.SubText}" FontSize="11">GreaseWeazle &#169; Keir Fraser &#8212; The Unlicense</Run>
                <LineBreak/>
                <Run Foreground="{DynamicResource Win.SubText}" FontSize="11">HxCFloppyEmulator &#169; Jean-Francois Del Nero &#8212; GPL v3</Run>
              </TextBlock>
            </StackPanel>
          </Border>
          <TextBlock Text="HOW TO USE" Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>
          <TextBlock TextWrapping="Wrap" LineHeight="22"
                     Foreground="{DynamicResource Win.Text}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="{DynamicResource Win.FontSize}">
            <Run FontWeight="SemiBold">1. Connect</Run><Run> the GreaseWeazle USB adapter and floppy drive.</Run>
            <LineBreak/>
            <Run FontWeight="SemiBold">2. Select READ</Run><Run> to save a floppy to a file, or </Run>
            <Run FontWeight="SemiBold">WRITE</Run><Run> to burn an image to floppy.</Run>
            <LineBreak/>
            <Run FontWeight="SemiBold">3. Choose format</Run><Run> matching your target computer.</Run>
            <LineBreak/>
            <Run FontWeight="SemiBold">4. Set file path</Run><Run> or Browse. Format is auto-detected where possible.</Run>
            <LineBreak/>
            <Run FontWeight="SemiBold">5. Click RUN.</Run><Run> Output streams live to the log.</Run>
          </TextBlock>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</Window>
