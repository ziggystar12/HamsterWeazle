<Window x:Class="HamsterWeazle.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="False" Width="520" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Win.Panel}">

  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="32" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="0"/>
  </WindowChrome.WindowChrome>

  <Border BorderBrush="{DynamicResource Win.Separator}" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="32"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Grid Grid.Row="0" Background="{DynamicResource Win.TitleBar.BG}"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Settings"
                   Foreground="{DynamicResource Win.TitleBar.FG}"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="13" FontWeight="SemiBold"
                   VerticalAlignment="Center" Margin="12,0"/>
        <Button Grid.Column="1" Style="{DynamicResource GhostBtn}"
                Foreground="{DynamicResource Win.TitleBar.FG}"
                Content="X" Width="46" Height="32" Click="BtnClose_Click"
                WindowChrome.IsHitTestVisibleInChrome="True"/>
      </Grid>

      <!-- Content -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,20">

          <!-- ABOUT -->
          <TextBlock Text="ABOUT"
                     Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>

          <TextBlock Text="HamsterWeazle"
                     Foreground="{DynamicResource Win.Text}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>

          <TextBlock x:Name="TxtVersion"
                     Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="{DynamicResource Win.FontSize}"
                     Margin="0,0,0,2"/>

          <TextBlock Text="John Swiderski  &#183;  Mean Hamster Software"
                     Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="{DynamicResource Win.FontSize}"
                     Margin="0,0,0,12"/>

          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="Source: "
                       Foreground="{DynamicResource Win.SubText}"
                       FontFamily="{DynamicResource Win.FontMain}"
                       FontSize="{DynamicResource Win.FontSize}"
                       VerticalAlignment="Center"/>
            <Button x:Name="BtnGitHub" Style="{DynamicResource GhostBtn}"
                    Content="github.com/ziggystar12/HamsterWeazle"
                    Foreground="{DynamicResource Win.Accent}"
                    Padding="0" Height="22" Click="BtnGitHub_Click"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="Web: "
                       Foreground="{DynamicResource Win.SubText}"
                       FontFamily="{DynamicResource Win.FontMain}"
                       FontSize="{DynamicResource Win.FontSize}"
                       VerticalAlignment="Center"/>
            <Button x:Name="BtnMeanHamster" Style="{DynamicResource GhostBtn}"
                    Content="meanhamster.com"
                    Foreground="{DynamicResource Win.Accent}"
                    Padding="0" Height="22" Click="BtnMeanHamster_Click"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="GreaseWeazle: "
                       Foreground="{DynamicResource Win.SubText}"
                       FontFamily="{DynamicResource Win.FontMain}"
                       FontSize="{DynamicResource Win.FontSize}"
                       VerticalAlignment="Center"/>
            <Button x:Name="BtnGwGitHub" Style="{DynamicResource GhostBtn}"
                    Content="github.com/keirf/greaseweazle"
                    Foreground="{DynamicResource Win.Accent}"
                    Padding="0" Height="22" Click="BtnGwGitHub_Click"/>
          </StackPanel>

          <Rectangle Style="{DynamicResource HSep}" Margin="0,0,0,16"/>

          <!-- THEME -->
          <TextBlock Text="THEME"
                     Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>

          <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <RadioButton x:Name="RbDark" Content="Dark"
                         GroupName="Theme"
                         Foreground="{DynamicResource Win.Text}"
                         FontFamily="{DynamicResource Win.FontMain}"
                         FontSize="{DynamicResource Win.FontSize}"
                         VerticalAlignment="Center" Margin="0,0,24,0"
                         Checked="RbTheme_Checked"/>
            <RadioButton x:Name="RbAmiga" Content="Amiga Workbench"
                         GroupName="Theme"
                         Foreground="{DynamicResource Win.Text}"
                         FontFamily="{DynamicResource Win.FontMain}"
                         FontSize="{DynamicResource Win.FontSize}"
                         VerticalAlignment="Center"
                         Checked="RbTheme_Checked"/>
          </StackPanel>

          <Rectangle Style="{DynamicResource HSep}" Margin="0,0,0,16"/>

          <!-- UPDATES -->
          <TextBlock Text="SOFTWARE UPDATES"
                     Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>

          <!-- HamsterWeazle update row -->
          <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
              <TextBlock Text="HamsterWeazle"
                         Foreground="{DynamicResource Win.Text}"
                         FontFamily="{DynamicResource Win.FontMain}"
                         FontSize="{DynamicResource Win.FontSize}"/>
              <TextBlock x:Name="TxtHwInstalled"
                         Foreground="{DynamicResource Win.SubText}"
                         FontFamily="{DynamicResource Win.FontMono}"
                         FontSize="11"/>
            </StackPanel>
            <TextBlock x:Name="TxtHwUpdateStatus" Grid.Column="1"
                       Foreground="{DynamicResource Win.SubText}"
                       FontFamily="{DynamicResource Win.FontMain}"
                       FontSize="{DynamicResource Win.FontSize}"
                       VerticalAlignment="Center" Margin="8,0"/>
            <Button x:Name="BtnCheckHw" Grid.Column="2"
                    Style="{DynamicResource PrimaryBtn}"
                    Content="Check" Height="30"
                    Click="BtnCheckHw_Click"/>
          </Grid>

          <!-- gw.exe update row -->
          <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
              <TextBlock Text="gw.exe (GreaseWeazle)"
                         Foreground="{DynamicResource Win.Text}"
                         FontFamily="{DynamicResource Win.FontMain}"
                         FontSize="{DynamicResource Win.FontSize}"/>
              <TextBlock x:Name="TxtGwInstalled"
                         Foreground="{DynamicResource Win.SubText}"
                         FontFamily="{DynamicResource Win.FontMono}"
                         FontSize="11"/>
            </StackPanel>
            <TextBlock x:Name="TxtGwUpdateStatus" Grid.Column="1"
                       Foreground="{DynamicResource Win.SubText}"
                       FontFamily="{DynamicResource Win.FontMain}"
                       FontSize="{DynamicResource Win.FontSize}"
                       VerticalAlignment="Center" Margin="8,0"/>
            <Button x:Name="BtnCheckGw" Grid.Column="2"
                    Style="{DynamicResource PrimaryBtn}"
                    Content="Check" Height="30"
                    Click="BtnCheckGw_Click"/>
          </Grid>

          <!-- HxCFloppyEmulator update row -->
          <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
              <TextBlock Text="HxCFloppyEmulator"
                         Foreground="{DynamicResource Win.Text}"
                         FontFamily="{DynamicResource Win.FontMain}"
                         FontSize="{DynamicResource Win.FontSize}"/>
              <TextBlock x:Name="TxtHxcInstalled"
                         Foreground="{DynamicResource Win.SubText}"
                         FontFamily="{DynamicResource Win.FontMono}"
                         FontSize="11"/>
            </StackPanel>
            <TextBlock x:Name="TxtHxcUpdateStatus" Grid.Column="1"
                       Foreground="{DynamicResource Win.SubText}"
                       FontFamily="{DynamicResource Win.FontMain}"
                       FontSize="{DynamicResource Win.FontSize}"
                       VerticalAlignment="Center" Margin="8,0"/>
            <Button x:Name="BtnCheckHxc" Grid.Column="2"
                    Style="{DynamicResource PrimaryBtn}"
                    Content="Check" Height="30"
                    Click="BtnCheckHxc_Click"/>
          </Grid>

          <Rectangle Style="{DynamicResource HSep}" Margin="0,0,0,16"/>

          <!-- INSTRUCTIONS -->
          <TextBlock Text="HOW TO USE"
                     Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>

          <TextBlock TextWrapping="Wrap" LineHeight="22"
                     Foreground="{DynamicResource Win.Text}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="{DynamicResource Win.FontSize}">
            <Run FontWeight="SemiBold">1. Connect</Run>
            <Run> the GreaseWeazle USB adapter to your PC and plug in a floppy drive.</Run>
            <LineBreak/>
            <Run FontWeight="SemiBold">2. Select READ</Run>
            <Run> to save a physical floppy to an image file, or </Run>
            <Run FontWeight="SemiBold">WRITE</Run>
            <Run> to burn an image file to a blank floppy.</Run>
            <LineBreak/>
            <Run FontWeight="SemiBold">3. Choose format</Run>
            <Run> matching your target computer (e.g. IBM 1440 for PC, amiga.amigados for Amiga).</Run>
            <LineBreak/>
            <Run FontWeight="SemiBold">4. Set file path</Run>
            <Run> or use Browse. READ saves to the Inbox folder by default.</Run>
            <LineBreak/>
            <Run FontWeight="SemiBold">5. Click RUN.</Run>
            <Run> Output streams live to the log panel. Cancel stops the operation safely.</Run>
            <LineBreak/>
            <Run FontWeight="SemiBold">Write Queue:</Run>
            <Run> every write is saved — click Run on any past entry to repeat it instantly.</Run>
          </TextBlock>

        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</Window>
