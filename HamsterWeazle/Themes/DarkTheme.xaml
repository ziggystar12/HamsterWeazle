<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- Fonts -->
  <FontFamily x:Key="Win.FontMain">Segoe UI</FontFamily>
  <FontFamily x:Key="Win.FontMono">Cascadia Mono, Consolas, Courier New</FontFamily>
  <sys:Double x:Key="Win.FontSize">13</sys:Double>
  <sys:Double x:Key="Win.FontSizeMono">12</sys:Double>

  <!-- Core colours -->
  <SolidColorBrush x:Key="Win.BG"              Color="#1E1E1E"/>
  <SolidColorBrush x:Key="Win.Panel"           Color="#252526"/>
  <SolidColorBrush x:Key="Win.Panel2"          Color="#2D2D30"/>
  <SolidColorBrush x:Key="Win.Text"            Color="#D4D4D4"/>
  <SolidColorBrush x:Key="Win.SubText"         Color="#858585"/>
  <SolidColorBrush x:Key="Win.Accent"          Color="#007ACC"/>
  <SolidColorBrush x:Key="Win.AccentHover"     Color="#1E8FDB"/>
  <SolidColorBrush x:Key="Win.Separator"       Color="#3C3C3C"/>
  <SolidColorBrush x:Key="Win.Highlight"       Color="#094771"/>
  <SolidColorBrush x:Key="Win.Success"         Color="#4EC9B0"/>
  <SolidColorBrush x:Key="Win.Warning"         Color="#CE9178"/>
  <SolidColorBrush x:Key="Win.Error"           Color="#F44747"/>

  <!-- Title bar -->
  <SolidColorBrush x:Key="Win.TitleBar.BG"     Color="#323233"/>
  <SolidColorBrush x:Key="Win.TitleBar.FG"     Color="#CCCCCC"/>
  <SolidColorBrush x:Key="Win.TitleBar.Close"  Color="#E81123"/>
  <SolidColorBrush x:Key="Win.TitleBar.Min"    Color="#3F3F41"/>

  <!-- Status bar -->
  <SolidColorBrush x:Key="Win.StatusBar.BG"    Color="#007ACC"/>
  <SolidColorBrush x:Key="Win.StatusBar.FG"    Color="#FFFFFF"/>

  <!-- Inputs -->
  <SolidColorBrush x:Key="Win.Input.BG"        Color="#3C3C3C"/>
  <SolidColorBrush x:Key="Win.Input.Border"    Color="#555555"/>
  <SolidColorBrush x:Key="Win.Input.FocusBdr"  Color="#007ACC"/>

  <!-- Buttons -->
  <SolidColorBrush x:Key="Win.Btn.BG"          Color="#0E639C"/>
  <SolidColorBrush x:Key="Win.Btn.FG"          Color="#FFFFFF"/>
  <SolidColorBrush x:Key="Win.Btn.Hover"       Color="#1177BB"/>
  <SolidColorBrush x:Key="Win.Btn.Pressed"     Color="#094771"/>
  <SolidColorBrush x:Key="Win.Btn.Disabled.BG" Color="#3C3C3C"/>
  <SolidColorBrush x:Key="Win.Btn.Disabled.FG" Color="#666666"/>
  <SolidColorBrush x:Key="Win.Btn.Ghost.Hover" Color="#3C3C3C"/>

  <!-- Op tabs -->
  <SolidColorBrush x:Key="Win.Tab.Active.BG"   Color="#1E1E1E"/>
  <SolidColorBrush x:Key="Win.Tab.Active.FG"   Color="#FFFFFF"/>
  <SolidColorBrush x:Key="Win.Tab.Active.Bdr"  Color="#007ACC"/>
  <SolidColorBrush x:Key="Win.Tab.Idle.BG"     Color="#2D2D30"/>
  <SolidColorBrush x:Key="Win.Tab.Idle.FG"     Color="#999999"/>

  <!-- Log panel -->
  <SolidColorBrush x:Key="Win.Log.BG"          Color="#0C0C0C"/>
  <SolidColorBrush x:Key="Win.Log.FG"          Color="#CCCCCC"/>

  <!-- Command preview -->
  <SolidColorBrush x:Key="Win.Cmd.BG"          Color="#1A1A2E"/>
  <SolidColorBrush x:Key="Win.Cmd.FG"          Color="#569CD6"/>

  <!-- Amiga 3-D edge colours (unused in Dark, defined for style compatibility) -->
  <SolidColorBrush x:Key="Amiga.Highlight"     Color="#555555"/>
  <SolidColorBrush x:Key="Amiga.Shadow"        Color="#000000"/>

  <!-- Scalars -->
  <sys:Double  x:Key="Win.CornerRadius">3</sys:Double>
  <CornerRadius x:Key="Win.Corner">3</CornerRadius>
  <CornerRadius x:Key="Win.CornerBtn">3</CornerRadius>
  <Thickness   x:Key="Win.BtnPadding">14,6</Thickness>
  <sys:String  x:Key="Win.ThemeName">Dark</sys:String>
  <sys:String  x:Key="Win.ThemeToggleLabel">Amiga</sys:String>

  <!-- TextBox -->
  <Style TargetType="TextBox">
    <Setter Property="Background"               Value="{DynamicResource Win.Input.BG}"/>
    <Setter Property="Foreground"               Value="{DynamicResource Win.Text}"/>
    <Setter Property="BorderBrush"              Value="{DynamicResource Win.Input.Border}"/>
    <Setter Property="BorderThickness"          Value="1"/>
    <Setter Property="Padding"                  Value="6,4"/>
    <Setter Property="FontFamily"               Value="{DynamicResource Win.FontMain}"/>
    <Setter Property="FontSize"                 Value="{DynamicResource Win.FontSize}"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="CaretBrush"               Value="{DynamicResource Win.Accent}"/>
    <Style.Triggers>
      <Trigger Property="IsFocused" Value="True">
        <Setter Property="BorderBrush" Value="{DynamicResource Win.Input.FocusBdr}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ComboBox -->
  <Style TargetType="ComboBox">
    <Setter Property="Background"        Value="{DynamicResource Win.Input.BG}"/>
    <Setter Property="Foreground"        Value="{DynamicResource Win.Text}"/>
    <Setter Property="BorderBrush"       Value="{DynamicResource Win.Input.Border}"/>
    <Setter Property="BorderThickness"   Value="1"/>
    <Setter Property="FontFamily"        Value="{DynamicResource Win.FontMain}"/>
    <Setter Property="FontSize"          Value="{DynamicResource Win.FontSize}"/>
    <Setter Property="Height"            Value="30"/>
    <Setter Property="MaxDropDownHeight" Value="300"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="22"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Bd" Grid.ColumnSpan="2"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{DynamicResource Win.Corner}"/>
            <ContentPresenter Grid.Column="0" Margin="8,0,0,0"
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              VerticalAlignment="Center" IsHitTestVisible="False"/>
            <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                  Fill="{DynamicResource Win.SubText}"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  IsHitTestVisible="False"/>
            <Popup x:Name="PART_Popup" AllowsTransparency="True"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   Placement="Bottom" StaysOpen="False"
                   MaxHeight="{TemplateBinding MaxDropDownHeight}">
              <Border Background="{DynamicResource Win.Input.BG}"
                      BorderBrush="{DynamicResource Win.Input.FocusBdr}"
                      BorderThickness="1" SnapsToDevicePixels="True">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <ItemsPresenter/>
                </ScrollViewer>
              </Border>
            </Popup>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Win.Input.FocusBdr}"/>
            </Trigger>
            <Trigger Property="IsDropDownOpen" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Win.Accent}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ComboBoxItem">
    <Setter Property="Background"  Value="{DynamicResource Win.Input.BG}"/>
    <Setter Property="Foreground"  Value="{DynamicResource Win.Text}"/>
    <Setter Property="Padding"     Value="8,4"/>
    <Setter Property="FontFamily"  Value="{DynamicResource Win.FontMain}"/>
    <Style.Triggers>
      <Trigger Property="IsHighlighted" Value="True">
        <Setter Property="Background" Value="{DynamicResource Win.Highlight}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- Label -->
  <Style TargetType="Label">
    <Setter Property="Foreground"               Value="{DynamicResource Win.SubText}"/>
    <Setter Property="FontFamily"               Value="{DynamicResource Win.FontMain}"/>
    <Setter Property="FontSize"                 Value="{DynamicResource Win.FontSize}"/>
    <Setter Property="Padding"                  Value="0,0,8,0"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <!-- Primary Button (flat modern) -->
  <Style x:Key="PrimaryBtn" TargetType="Button">
    <Setter Property="Background"      Value="{DynamicResource Win.Btn.BG}"/>
    <Setter Property="Foreground"      Value="{DynamicResource Win.Btn.FG}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="{DynamicResource Win.BtnPadding}"/>
    <Setter Property="FontFamily"      Value="{DynamicResource Win.FontMain}"/>
    <Setter Property="FontSize"        Value="{DynamicResource Win.FontSize}"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd"
                  Background="{TemplateBinding Background}"
                  CornerRadius="{DynamicResource Win.CornerBtn}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource Win.Btn.Hover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource Win.Btn.Pressed}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource Win.Btn.Disabled.BG}"/>
              <Setter Property="Foreground"                  Value="{DynamicResource Win.Btn.Disabled.FG}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Ghost Button (title bar controls, browse) -->
  <Style x:Key="GhostBtn" TargetType="Button">
    <Setter Property="Background"      Value="Transparent"/>
    <Setter Property="Foreground"      Value="{DynamicResource Win.Text}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding"         Value="8,4"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="FontFamily"      Value="{DynamicResource Win.FontMain}"/>
    <Setter Property="FontSize"        Value="{DynamicResource Win.FontSize}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="bd"
                  Background="{TemplateBinding Background}"
                  CornerRadius="{DynamicResource Win.CornerBtn}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource Win.Btn.Ghost.Hover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource Win.Btn.Pressed}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Op-tab toggle button -->
  <Style x:Key="OpTabBtn" TargetType="ToggleButton">
    <Setter Property="Background"      Value="{DynamicResource Win.Tab.Idle.BG}"/>
    <Setter Property="Foreground"      Value="{DynamicResource Win.Tab.Idle.FG}"/>
    <Setter Property="BorderThickness" Value="0,0,0,3"/>
    <Setter Property="BorderBrush"     Value="Transparent"/>
    <Setter Property="Padding"         Value="18,0"/>
    <Setter Property="FontFamily"      Value="{DynamicResource Win.FontMain}"/>
    <Setter Property="FontSize"        Value="{DynamicResource Win.FontSize}"/>
    <Setter Property="FontWeight"      Value="SemiBold"/>
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="Height"          Value="40"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Border x:Name="bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="bd" Property="Background"   Value="{DynamicResource Win.Tab.Active.BG}"/>
              <Setter Property="Foreground"                    Value="{DynamicResource Win.Tab.Active.FG}"/>
              <Setter TargetName="bd" Property="BorderBrush"  Value="{DynamicResource Win.Tab.Active.Bdr}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="bd" Property="Background" Value="{DynamicResource Win.Panel2}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Horizontal separator -->
  <Style x:Key="HSep" TargetType="Rectangle">
    <Setter Property="Height"               Value="1"/>
    <Setter Property="Fill"                 Value="{DynamicResource Win.Separator}"/>
    <Setter Property="HorizontalAlignment"  Value="Stretch"/>
  </Style>

</ResourceDictionary>
