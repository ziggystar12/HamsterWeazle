<Window x:Class="HamsterWeazle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HamsterWeazle" WindowStyle="None" ResizeMode="CanResize"
        AllowsTransparency="False" Background="{DynamicResource Win.BG}"
        MinWidth="1100" MinHeight="650" Width="1500" Height="760"
        StateChanged="Window_StateChanged">

  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="32" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
  </WindowChrome.WindowChrome>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="32"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Title bar -->
    <Grid Grid.Row="0" Background="{DynamicResource Win.TitleBar.BG}"
          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
        <Image Source="pack://application:,,,/Assets/logo24.png"
               Width="22" Height="22" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
        <TextBlock Text="HamsterWeazle"
                   Foreground="{DynamicResource Win.TitleBar.FG}"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="13" FontWeight="SemiBold"
                   VerticalAlignment="Center"/>
        <TextBlock x:Name="TxtTitleVersion"
                   Foreground="{DynamicResource Win.TitleBar.FG}"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="11" Opacity="0.65"
                   VerticalAlignment="Center" Margin="6,1,0,0"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
        <Button x:Name="BtnWhatsNew"
                Style="{DynamicResource GhostBtn}"
                Foreground="{DynamicResource Win.TitleBar.FG}"
                FontSize="13" Padding="8,0" Height="32" Click="BtnWhatsNew_Click"
                WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="What's New">
          <Grid>
            <TextBlock Text="&#x2605;" VerticalAlignment="Center"/>
            <Ellipse x:Name="WhatsNewDot" Width="7" Height="7"
                     Fill="#FF4444" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-2,-2,0" Visibility="Collapsed"/>
          </Grid>
        </Button>
        <Button x:Name="BtnSettings" Content="&#x2699;"
                Style="{DynamicResource GhostBtn}"
                Foreground="{DynamicResource Win.TitleBar.FG}"
                FontSize="15" Padding="10,0" Height="32" Click="BtnSettings_Click"
                WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Settings"/>
        <Popup x:Name="WhatsNewPopup" Placement="Bottom" StaysOpen="False"
               AllowsTransparency="True" PopupAnimation="Fade">
          <Border Background="{DynamicResource Win.Panel2}"
                  BorderBrush="{DynamicResource Win.Separator}" BorderThickness="1"
                  Width="360" MaxHeight="440">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Margin="16,14,16,16">
                <TextBlock x:Name="TxtWhatsNewHeader"
                           FontFamily="{DynamicResource Win.FontMain}"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{DynamicResource Win.SubText}"
                           Margin="0,0,0,10"/>
                <TextBlock x:Name="TxtWhatsNew" TextWrapping="Wrap"
                           FontFamily="{DynamicResource Win.FontMain}"
                           FontSize="{DynamicResource Win.FontSize}"
                           Foreground="{DynamicResource Win.Text}"
                           LineHeight="20"/>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </Popup>
        <ComboBox x:Name="CboDevice"
                  Width="90" Height="22" Margin="0,0,4,0"
                  Background="#1A1A1A" Foreground="{DynamicResource Win.TitleBar.FG}"
                  BorderBrush="#444444" BorderThickness="1"
                  FontFamily="{DynamicResource Win.FontMono}" FontSize="11"
                  ToolTip="COM port — Auto lets gw.exe detect the device"
                  SelectionChanged="CboDevice_SelectionChanged"
                  WindowChrome.IsHitTestVisibleInChrome="True"/>
        <Button x:Name="BtnMinimize" Style="{DynamicResource GhostBtn}"
                Foreground="{DynamicResource Win.TitleBar.FG}"
                Content="_" Width="46" Height="32" Click="BtnMinimize_Click"
                WindowChrome.IsHitTestVisibleInChrome="True"/>
        <Button x:Name="BtnMaximize" Style="{DynamicResource GhostBtn}"
                Foreground="{DynamicResource Win.TitleBar.FG}"
                Content="[]" Width="46" Height="32" Click="BtnMaximize_Click"
                WindowChrome.IsHitTestVisibleInChrome="True"/>
        <Button x:Name="BtnClose" Style="{DynamicResource GhostBtn}"
                Foreground="{DynamicResource Win.TitleBar.FG}"
                Content="X" Width="46" Height="32" Click="BtnClose_Click"
                WindowChrome.IsHitTestVisibleInChrome="True"/>
      </StackPanel>
    </Grid>

    <!-- Update notification banner (hidden until an update is available) -->
    <Border x:Name="UpdateBanner" Grid.Row="1" Visibility="Collapsed"
            Background="{DynamicResource Win.Accent}" Padding="10,0">
      <Grid Height="30">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="TxtUpdateMsg" Grid.Column="0"
                   Foreground="#FFFFFF"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="{DynamicResource Win.FontSize}"
                   VerticalAlignment="Center"/>
        <Button x:Name="BtnDoUpdate" Grid.Column="1"
                Style="{DynamicResource GhostBtn}"
                Foreground="#FFFFFF" FontWeight="SemiBold"
                Height="30" Padding="12,0" Margin="8,0,0,0"
                Content="Update Now" Click="BtnDoUpdate_Click"/>
        <Button x:Name="BtnDismissUpdate" Grid.Column="2"
                Style="{DynamicResource GhostBtn}"
                Foreground="#FFFFFF" Content="X"
                Height="30" Width="30" Padding="0"
                Click="BtnDismissUpdate_Click"/>
      </Grid>
    </Border>

    <!-- Main split: left content | sidebar -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="1"/>
        <ColumnDefinition Width="320"/>
      </Grid.ColumnDefinitions>

      <!-- Left panel -->
      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="1"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="1"/>
          <RowDefinition Height="36"/>
          <RowDefinition Height="40"/>
          <RowDefinition Height="1"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Op tabs -->
        <Grid Grid.Row="0" Background="{DynamicResource Win.Panel}">
          <StackPanel Orientation="Horizontal" Margin="8,4">
            <ToggleButton x:Name="TabRead"  Style="{DynamicResource OpTabBtn}" Content="Read"
                          IsChecked="True" Click="OpTab_Click" Tag="Read"  Margin="0,0,4,0"/>
            <ToggleButton x:Name="TabWrite" Style="{DynamicResource OpTabBtn}" Content="Write"
                          Click="OpTab_Click" Tag="Write" Margin="0,0,4,0"/>
            <ToggleButton x:Name="TabErase" Style="{DynamicResource OpTabBtn}" Content="Erase"
                          Click="OpTab_Click" Tag="Erase" Margin="0,0,4,0"/>
            <ToggleButton x:Name="TabTools" Style="{DynamicResource OpTabBtn}" Content="Tools"
                          Click="OpTab_Click" Tag="Tools" Margin="0,0,4,0"/>
            <ToggleButton x:Name="TabInfo"  Style="{DynamicResource OpTabBtn}" Content="Info"
                          Click="OpTab_Click" Tag="Info"/>
          </StackPanel>
        </Grid>

        <Rectangle Grid.Row="1" Style="{DynamicResource HSep}"/>

        <!-- Content panel -->
        <Border Grid.Row="2" Background="{DynamicResource Win.Panel}" Padding="12,10">
          <StackPanel>
            <Grid x:Name="PanelFormat" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Label Grid.Column="0" Content="Vendor"/>
              <ComboBox x:Name="CboVendor" Grid.Column="1" SelectionChanged="CboVendor_SelectionChanged"/>
              <Label Grid.Column="2"/>
              <ComboBox x:Name="CboFormat" Grid.Column="3" SelectionChanged="CboFormat_SelectionChanged"/>
            </Grid>
            <Grid x:Name="PanelFile" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="80"/>
              </Grid.ColumnDefinitions>
              <Label x:Name="LblFile" Grid.Column="0" Content="Output"/>
              <TextBox x:Name="TxtFile" Grid.Column="1" TextChanged="Options_Changed"/>
              <Button x:Name="BtnBrowse" Grid.Column="3" Style="{DynamicResource GhostBtn}"
                      Content="Browse..." Click="BtnBrowse_Click"/>
            </Grid>
            <TextBlock x:Name="TxtAutoDetect" Visibility="Collapsed"
                       Margin="70,0,0,6"
                       Foreground="{DynamicResource Win.Success}"
                       FontFamily="{DynamicResource Win.FontMain}"
                       FontSize="11"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Expander x:Name="AdvExpander" Grid.Column="0" Header="Advanced" IsExpanded="False"
                        Foreground="{DynamicResource Win.SubText}"
                        FontFamily="{DynamicResource Win.FontMain}"
                        FontSize="{DynamicResource Win.FontSize}">
              <StackPanel Margin="0,6,0,0">
                <!-- Row 1: Presets -->
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Label Grid.Column="0" Content="Preset"/>
                  <ComboBox x:Name="CboPreset" Grid.Column="1"
                            SelectionChanged="CboPreset_SelectionChanged"/>
                  <Button x:Name="BtnSavePreset" Grid.Column="3"
                          Style="{DynamicResource GhostBtn}"
                          Content="Save" Padding="10,2"
                          Click="BtnSavePreset_Click"/>
                  <Button x:Name="BtnDeletePreset" Grid.Column="5"
                          Style="{DynamicResource GhostBtn}"
                          Content="Delete" Padding="10,2"
                          Click="BtnDeletePreset_Click"/>
                </Grid>
                <!-- Row 2: Cyls / Retries / Verify -->
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Label Grid.Column="0" Content="Cyls"/>
                  <TextBox x:Name="TxtCylStart" Grid.Column="1" Text="0"  TextChanged="Options_Changed"/>
                  <Label Grid.Column="2" Content="-" HorizontalContentAlignment="Center"/>
                  <TextBox x:Name="TxtCylEnd"   Grid.Column="3" Text="79" TextChanged="Options_Changed"/>
                  <Label Grid.Column="4" Content="Retries"/>
                  <TextBox x:Name="TxtRetries"  Grid.Column="5" Text="3"  TextChanged="Options_Changed"/>
                  <CheckBox x:Name="ChkVerify" Grid.Column="7"
                            Content="Verify after write" IsChecked="False"
                            Foreground="{DynamicResource Win.Text}"
                            FontFamily="{DynamicResource Win.FontMain}"
                            FontSize="{DynamicResource Win.FontSize}"
                            VerticalAlignment="Center" Margin="10,0"
                            Checked="Options_Changed" Unchecked="Options_Changed"/>
                </Grid>
                <!-- Row 3: Drive selector -->
                <Grid Margin="0,6,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Label Grid.Column="0" Content="Drive"/>
                  <ComboBox x:Name="CboDrive" Grid.Column="1"
                            SelectedIndex="0"
                            SelectionChanged="Options_Changed">
                    <ComboBoxItem Content="Auto"/>
                    <ComboBoxItem Content="PC cable A: / Drive 0" Tag="0"/>
                    <ComboBoxItem Content="PC cable B: / Drive 1" Tag="1"/>
                    <ComboBoxItem Content="Shugart DS0 / Drive 0" Tag="0"/>
                    <ComboBoxItem Content="Shugart DS1 / Drive 1" Tag="1"/>
                    <ComboBoxItem Content="Shugart DS2 / Drive 2" Tag="2"/>
                    <ComboBoxItem Content="Shugart DS3 / Drive 3" Tag="3"/>
                  </ComboBox>
                  <CheckBox x:Name="ChkCustomOutput" Grid.Column="3"
                            Content="Custom output path"
                            Foreground="{DynamicResource Win.Text}"
                            FontFamily="{DynamicResource Win.FontMain}"
                            FontSize="{DynamicResource Win.FontSize}"
                            VerticalAlignment="Center" Margin="16,0,0,0"
                            Checked="ChkCustomOutput_Changed"
                            Unchecked="ChkCustomOutput_Changed"/>
                </Grid>
                <!-- Row 4: Revolutions (Read only) -->
                <Grid x:Name="PanelRevs">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Label Grid.Column="0" Content="Revs"/>
                  <TextBox x:Name="TxtRevs" Grid.Column="1" Text="1" TextChanged="Options_Changed"/>
                  <TextBlock Grid.Column="2" Text="flux revolutions per track (1=fast, 3-5=reliable on worn disks)"
                             Foreground="{DynamicResource Win.SubText}"
                             FontFamily="{DynamicResource Win.FontMain}"
                             FontSize="10" VerticalAlignment="Center" Margin="8,0"/>
                </Grid>
              </StackPanel>
            </Expander>
              <CheckBox x:Name="ChkAutoDetect" Grid.Column="1"
                        Content="Auto Detect 3.5&quot;/5.25&quot;"
                        Foreground="{DynamicResource Win.SubText}"
                        FontFamily="{DynamicResource Win.FontMain}"
                        FontSize="{DynamicResource Win.FontSize}"
                        VerticalAlignment="Top" Margin="12,4,0,0"
                        IsChecked="True"
                        Checked="ChkAutoDetect_Changed"
                        Unchecked="ChkAutoDetect_Changed"/>
            </Grid>
            <TextBlock x:Name="PanelErase" Visibility="Collapsed"
                       Text="All data on the floppy will be permanently erased."
                       Foreground="{DynamicResource Win.Warning}"
                       FontFamily="{DynamicResource Win.FontMain}"
                       FontSize="{DynamicResource Win.FontSize}"
                       TextWrapping="Wrap" Margin="0,6"/>
            <StackPanel x:Name="PanelTools" Visibility="Collapsed">
              <Button x:Name="BtnUpdateFirmware" Style="{DynamicResource PrimaryBtn}"
                      Content="Update Device Firmware"
                      HorizontalAlignment="Left" Height="36" MinWidth="220"
                      Margin="0,0,0,8" Click="BtnUpdateFirmware_Click"/>
              <Button x:Name="BtnCleanDrive" Style="{DynamicResource PrimaryBtn}"
                      Content="Floppy Drive Cleaner..."
                      HorizontalAlignment="Left" Height="36" MinWidth="220"
                      Margin="0,0,0,8" Click="BtnCleanDrive_Click"/>
              <Button x:Name="BtnResetGw" Style="{DynamicResource PrimaryBtn}"
                      Content="Reset GreaseWeazle"
                      HorizontalAlignment="Left" Height="36" MinWidth="220"
                      Click="BtnResetGw_Click"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <Rectangle Grid.Row="3" Style="{DynamicResource HSep}"/>

        <!-- Command preview -->
        <Border Grid.Row="4" Background="{DynamicResource Win.Cmd.BG}" Padding="10,0">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="$ "
                       Foreground="{DynamicResource Win.SubText}"
                       FontFamily="{DynamicResource Win.FontMono}"
                       FontSize="{DynamicResource Win.FontSizeMono}"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="TxtCmdPreview" Grid.Column="1"
                       Foreground="{DynamicResource Win.Cmd.FG}"
                       FontFamily="{DynamicResource Win.FontMono}"
                       FontSize="{DynamicResource Win.FontSizeMono}"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                       Text="(select format and file to preview the command)"/>
          </Grid>
        </Border>

        <!-- Run / Cancel -->
        <Grid Grid.Row="5" Background="{DynamicResource Win.Panel2}">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                      VerticalAlignment="Center" Margin="12,0">
            <Button x:Name="BtnAutoRead" Style="{DynamicResource GhostBtn}"
                    Content="Auto Read" FontWeight="SemiBold"
                    Visibility="Collapsed"
                    Click="BtnAutoRead_Click" Height="36" MinWidth="110" Margin="0,0,8,0"/>
            <Button x:Name="BtnRun" Style="{DynamicResource PrimaryBtn}"
                    Content="  READ  " FontWeight="Bold"
                    Click="BtnRun_Click" Height="36" MinWidth="120"/>
            <Button x:Name="BtnCancel" Style="{DynamicResource GhostBtn}"
                    Content="  CANCEL  " IsEnabled="False"
                    Click="BtnCancel_Click" Height="36" MinWidth="100" Margin="10,0,0,0"/>
          </StackPanel>
          <ProgressBar x:Name="ProgressBar"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       Width="200" Height="10" Margin="0,0,12,0"
                       Visibility="Collapsed" IsIndeterminate="True"
                       Foreground="{DynamicResource Win.Accent}"
                       Background="{DynamicResource Win.Panel}"
                       BorderBrush="{DynamicResource Win.Separator}"/>
        </Grid>

        <Rectangle Grid.Row="6" Style="{DynamicResource HSep}"/>

        <!-- Drive status -->
        <Grid Grid.Row="7">
          <Grid.RowDefinitions>
            <RowDefinition Height="22"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Background="{DynamicResource Win.Panel2}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="DRIVE"
                       Foreground="{DynamicResource Win.SubText}"
                       FontFamily="{DynamicResource Win.FontMain}"
                       FontSize="10" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="10,0"/>
            <Button x:Name="BtnClearLog" Grid.Column="1" Style="{DynamicResource GhostBtn}"
                    Content="Clear Issues" FontSize="10" Height="22" Padding="8,0"
                    Click="BtnClearLog_Click"/>
          </Grid>
          <Grid Grid.Row="1" Background="{DynamicResource Win.Log.BG}">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Viewbox Grid.Row="0" Stretch="Uniform" Margin="18,8,18,4">
              <Canvas Width="640" Height="190">
                <Border Canvas.Left="20" Canvas.Top="10" Width="600" Height="166"
                        Background="#202020" BorderBrush="#050505" BorderThickness="4"
                        CornerRadius="8"/>
                <Border Canvas.Left="38" Canvas.Top="28" Width="564" Height="132"
                        Background="#383838" BorderBrush="#585858" BorderThickness="2"
                        CornerRadius="5"/>
                <Rectangle Canvas.Left="56" Canvas.Top="38" Width="526" Height="1" Fill="#686868" Opacity="0.45"/>
                <Rectangle Canvas.Left="56" Canvas.Top="143" Width="526" Height="1" Fill="#161616" Opacity="0.85"/>
                <StackPanel Canvas.Left="56" Canvas.Top="48" Width="70" Height="92"
                            HorizontalAlignment="Center">
                  <TextBlock x:Name="DriveFamilyLabel" Width="70" Height="21"
                             Text="5.25&quot;"
                             Foreground="{DynamicResource Win.Log.FG}"
                             FontFamily="{DynamicResource Win.FontMono}"
                             FontSize="20" FontWeight="Bold"
                             LineHeight="21" TextAlignment="Center"/>
                  <TextBlock x:Name="DriveWordLabel" Width="70" Height="21"
                             Text="DRIVE"
                             Foreground="{DynamicResource Win.Log.FG}"
                             FontFamily="{DynamicResource Win.FontMono}"
                             FontSize="20" FontWeight="Bold"
                             LineHeight="21" TextAlignment="Center"/>
                  <Grid Width="30" Height="30" Margin="0,16,0,0"
                        HorizontalAlignment="Center">
                    <Ellipse Width="30" Height="30"
                             Fill="#050505" Stroke="#111111" StrokeThickness="3"/>
                    <Ellipse x:Name="DriveLed" Width="16" Height="16"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Fill="#1C4D28" Opacity="0.45"/>
                  </Grid>
                </StackPanel>
                <Border x:Name="Drive525Face" Canvas.Left="154" Canvas.Top="54" Width="430" Height="84"
                        Background="#141414" BorderBrush="#050505" BorderThickness="3"
                        CornerRadius="1"/>
                <Border x:Name="Drive525Slot" Canvas.Left="174" Canvas.Top="70" Width="360" Height="16"
                        Background="#080808" BorderBrush="#111111" BorderThickness="3"
                        CornerRadius="2"/>
                <Border x:Name="Drive525Latch" Canvas.Left="516" Canvas.Top="106" Width="50" Height="28"
                        Background="#242424" BorderBrush="#050505" BorderThickness="3"
                        CornerRadius="3"/>
                <Rectangle x:Name="Drive525LatchLine" Canvas.Left="520" Canvas.Top="132" Width="42" Height="3"
                           Fill="#303030"/>
                <Border x:Name="Drive35Face" Canvas.Left="154" Canvas.Top="54" Width="430" Height="84"
                        Background="#141414" BorderBrush="#050505" BorderThickness="3"
                        CornerRadius="1" Visibility="Collapsed"/>
                <Border x:Name="Drive35Bezel" Canvas.Left="174" Canvas.Top="70" Width="360" Height="16"
                        Background="#080808" BorderBrush="#111111" BorderThickness="3"
                        CornerRadius="2" Visibility="Collapsed"/>
                <Border x:Name="Drive35Slot" Canvas.Left="176" Canvas.Top="73" Width="356" Height="14"
                        Background="#050505" BorderBrush="#000000" BorderThickness="2"
                        CornerRadius="2" Visibility="Collapsed"/>
                <Border x:Name="Drive35Button" Canvas.Left="516" Canvas.Top="106" Width="50" Height="28"
                        Background="#252525" BorderBrush="#050505" BorderThickness="3"
                        CornerRadius="3" Visibility="Collapsed"/>
                <Rectangle x:Name="Drive35ButtonLine" Canvas.Left="520" Canvas.Top="132" Width="42" Height="3"
                           Fill="#151515" Visibility="Collapsed"/>
                <TextBlock x:Name="DriveStatusText" Canvas.Left="225" Canvas.Top="144" Width="270"
                           Text="Ready"
                           Foreground="{DynamicResource Win.SubText}"
                           FontFamily="{DynamicResource Win.FontMono}"
                           FontSize="13" FontWeight="SemiBold"
                           TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
              </Canvas>
            </Viewbox>
            <Border x:Name="ErrorConsolePanel" Grid.Row="1" Visibility="Collapsed"
                    Background="#000000" BorderBrush="{DynamicResource Win.Error}"
                    BorderThickness="1,1,0,0" MaxHeight="96">
              <ScrollViewer x:Name="LogScroll"
                            VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <TextBox x:Name="TxtLog" IsReadOnly="True" TextWrapping="Wrap"
                         Background="#000000"
                         Foreground="{DynamicResource Win.Log.FG}"
                         FontFamily="{DynamicResource Win.FontMono}"
                         FontSize="{DynamicResource Win.FontSizeMono}"
                         BorderThickness="0" Padding="10,7"
                         VerticalScrollBarVisibility="Disabled"
                         HorizontalScrollBarVisibility="Disabled"
                         AcceptsReturn="True"/>
              </ScrollViewer>
            </Border>
          </Grid>
        </Grid>
      </Grid>

      <!-- Vertical separator -->
      <Rectangle Grid.Column="1" Fill="{DynamicResource Win.Separator}"
                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

      <!-- Right sidebar -->
      <Grid Grid.Column="2" Background="{DynamicResource Win.Panel}">
        <Grid.RowDefinitions>
          <RowDefinition Height="28"/>
          <RowDefinition Height="330"/>
          <RowDefinition Height="1"/>
          <RowDefinition Height="28"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Write Queue header -->
        <Grid Grid.Row="0" Background="{DynamicResource Win.Panel2}">
          <TextBlock Text="WRITE QUEUE"
                     Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="10" FontWeight="SemiBold"
                     VerticalAlignment="Center" Margin="10,0"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="WriteQueuePanel"/>
        </ScrollViewer>

        <Rectangle Grid.Row="2" Style="{DynamicResource HSep}"/>

        <!-- Inbox header -->
        <Grid Grid.Row="3" Background="{DynamicResource Win.Panel2}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="INBOX"
                     Foreground="{DynamicResource Win.SubText}"
                     FontFamily="{DynamicResource Win.FontMain}"
                     FontSize="10" FontWeight="SemiBold"
                     VerticalAlignment="Center" Margin="10,0"/>
          <Button x:Name="BtnOpenInbox" Grid.Column="1"
                  Style="{DynamicResource GhostBtn}" Content="Open"
                  FontSize="10" Height="28" Padding="8,0"
                  Click="BtnOpenInbox_Click"/>
        </Grid>

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="InboxPanel"/>
        </ScrollViewer>
      </Grid>
    </Grid>

  </Grid>
</Window>
