<Window x:Class="HamsterWeazle.HxcSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HxCFloppyEmulator Setup"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="False" Width="480" Height="260"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Win.Panel}">

  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="32" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="0"/>
  </WindowChrome.WindowChrome>

  <Border BorderBrush="{DynamicResource Win.Separator}" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="32"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Background="{DynamicResource Win.TitleBar.BG}"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <TextBlock Text="HxCFloppyEmulator"
                   Foreground="{DynamicResource Win.TitleBar.FG}"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="13" FontWeight="SemiBold"
                   VerticalAlignment="Center" Margin="12,0"/>
      </Grid>

      <StackPanel Grid.Row="1" Margin="24,20,24,20">

        <TextBlock Text="Browse Disk Image Contents"
                   Foreground="{DynamicResource Win.Text}"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <TextBlock TextWrapping="Wrap"
                   Foreground="{DynamicResource Win.SubText}"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="{DynamicResource Win.FontSize}"
                   Margin="0,0,0,20">
          HxCFloppyEmulator lets you browse files inside disk images, list
          directory contents, and open images in its GUI. Download it now to
          enable List Files and Open HxC on every disk image in the app.
        </TextBlock>

        <Button x:Name="BtnDownload"
                Style="{DynamicResource PrimaryBtn}"
                Content="Checking for latest version..."
                HorizontalAlignment="Stretch" Height="38"
                IsEnabled="False" Click="BtnDownload_Click" Margin="0,0,0,8"/>

        <ProgressBar x:Name="ProgressBar" Height="6" Margin="0,0,0,4"
                     Visibility="Collapsed"
                     Foreground="{DynamicResource Win.Accent}"
                     Background="{DynamicResource Win.Input.BG}"
                     BorderBrush="{DynamicResource Win.Separator}"/>

        <TextBlock x:Name="TxtStatus"
                   Foreground="{DynamicResource Win.SubText}"
                   FontFamily="{DynamicResource Win.FontMain}"
                   FontSize="{DynamicResource Win.FontSize}"
                   Visibility="Collapsed" Margin="0,0,0,8"/>

        <Button x:Name="BtnSkip" Style="{DynamicResource GhostBtn}"
                Content="Skip for now (can be installed later from Settings)"
                HorizontalAlignment="Right" Height="26"
                Click="BtnSkip_Click"/>

      </StackPanel>
    </Grid>
  </Border>
</Window>
